{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:web",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/categories",
      "destination": "/index.html"
    },
    {
      "source": "/channels",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/feedback",
      "destination": "/index.html"
    },
    {
      "source": "/guides/:slug*",
      "destination": "/index.html"
    },
    {
      "source": "/404",
      "destination": "/index.html"
    }
  ]
}
